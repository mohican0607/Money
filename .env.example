# 네이버 개발자센터에서 발급 (https://developers.naver.com/apps/#/register)
# 애플리케이션에 **검색(뉴스)** API 가 켜져 있어야 합니다. 401이면 ID/Secret 재발급·복사 확인.
# 비워 두면 Google News RSS. 끄려면 USE_GOOGLE_NEWS_RSS_FALLBACK=0
# .env 는 프로젝트 루트(Money/)에 두세요. 값에 BOM/따옴표가 붙으면 코드에서 제거합니다.

NAVER_CLIENT_ID=CZ1fNuY7CbTu9ygZ2EgX
NAVER_CLIENT_SECRET=H36bdoK18Z
USE_GOOGLE_NEWS_RSS_FALLBACK=1
# Google RSS 쿼리 확장(기본값은 코드 내 시드). 더 많이: GOOGLE_NEWS_RSS_DUAL_LOCALE=1 (한·영 에디션 각 1회)
# GOOGLE_NEWS_RSS_QUERY_SLEEP_SEC=0.09
# GOOGLE_NEWS_RSS_DUAL_LOCALE=0
# https://developers.naver.com/apps/#/myapps/CZ1fNuY7CbTu9ygZ2EgX/overview



# 뉴스 없이 주식·리포트만 돌릴 때 1
MOCK_NEWS=0

# 디버깅: 상위 N개 종목만 가격 다운로드. 리포트의 「실제 20%↑」를 전 시장에 맞출 때는 비우거나 주석 처리.
# SAMPLE_TICKERS=200

# 빠른 시험: 테스트 거래일 수 제한 (0 또는 비우면 전체)
# MAX_TEST_DAYS=5

# 수집 속도(선택): 전종목 OHLCV 병렬 스레드(기본 12). 회선이 느리면 6~8
# OHLCV_MAX_WORKERS=12

# 뉴스는 날짜별 파일(day_*.json) 단위로 병렬(기본 4). 네이버 API 한도 에러 시 1~2
# NEWS_FETCH_MAX_WORKERS=4

# 네이버 뉴스: market(기본)=일자+증시 키워드 | ticker=종목별 YYYY년 M월 D일 {종목명}
# both=market+ticker 동시 수집·병합 (네이버 키 필수)
# NEWS_NAVER_QUERY_MODE=market
# 종목별 모드 시 하루 안에서 종목 쿼리 병렬 수·종목당 페이지(100건/페이지, 최대 10)
# NEWS_TICKER_NAVER_MAX_WORKERS=8
# NEWS_TICKER_NAVER_MAX_PAGES=2
